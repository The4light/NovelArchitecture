  -- Create the Chapters table linked to Novels
  CREATE TABLE public.chapters (
      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
      created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW() NOT NULL,
      novel_id BIGINT NOT NULL REFERENCES public.novels(id) ON DELETE CASCADE,
      title TEXT NOT NULL,
      content TEXT DEFAULT '',
      chapter_order INT NOT NULL,
      status TEXT NOT NULL DEFAULT 'Draft' -- Allows saving chapter drafts before publishing the book
  );

  -- Enable RLS
  ALTER TABLE public.chapters ENABLE ROW LEVEL SECURITY;

  -- RLS Policies for Chapters
  CREATE POLICY "Allow public read to published chapters" 
  ON public.chapters FOR SELECT 
  USING (
    EXISTS (
      SELECT 1 FROM public.novels 
      WHERE novels.id = chapters.novel_id AND (novels.status = 'Published' OR novels.user_id = auth.uid())
    )
  );

  CREATE POLICY "Allow authors to manage chapters" 
  ON public.chapters FOR ALL 
  USING (
    EXISTS (
      SELECT 1 FROM public.novels 
      WHERE novels.id = chapters.novel_id AND novels.user_id = auth.uid()
    )
  );


