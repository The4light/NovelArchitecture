  ON public.novels FOR SELECT USING (status = 'Published' OR auth.uid() = user_id);

  CREATE POLICY "Allow users to create their own novels" 
  ON public.novels FOR INSERT WITH CHECK (auth.uid() = user_id);

  CREATE POLICY "Allow users to update their own novels" 
  ON public.novels FOR UPDATE USING (auth.uid() = user_id);

  CREATE POLICY "Allow users to delete their own novels" 
