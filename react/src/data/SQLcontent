      created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW() NOT NULL,
      title TEXT NOT NULL,
      description TEXT,
      synopsis TEXT,
      genre TEXT NOT NULL DEFAULT 'Fantasy',
      is_mature BOOLEAN DEFAULT FALSE NOT NULL,
