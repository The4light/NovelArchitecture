  -- 1. Create the foundational Codex & Stickies table from scratch
  CREATE TABLE public.codex_entries (
      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,
      created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW() NOT NULL,
      novel_id BIGINT NOT NULL REFERENCES public.novels(id) ON DELETE CASCADE,
      title TEXT NOT NULL DEFAULT 'Untitled Node',
      category TEXT NOT NULL DEFAULT 'Scratchpad', -- 'Character', 'Lore', or 'Scratchpad'
      summary TEXT DEFAULT '',
      content TEXT DEFAULT '',
      
      -- Windows Sticky Floating Position Attributes
      is_floating BOOLEAN DEFAULT FALSE,
      position_x INT DEFAULT 150,
      position_y INT DEFAULT 150,
      bg_color TEXT DEFAULT '#fef08a' -- Classic Windows Yellow
  );

  -- 2. Enable Row Level Security
  ALTER TABLE public.codex_entries ENABLE ROW LEVEL SECURITY;

  -- 3. RLS Security Policies (Ensures only the project owner can manage entries)
  CREATE POLICY "Allow authors to manage codex entries" 
  ON public.codex_entries FOR ALL 
  USING (
    EXISTS (
      SELECT 1 FROM public.novels 
      WHERE novels.id = codex_entries.novel_id AND novels.user_id = auth.uid()
    )
  );

  CREATE POLICY "Allow public read to published novel codex entries" 
  ON public.codex_entries FOR SELECT 
  USING (
    EXISTS (
      SELECT 1 FROM public.novels 
      WHERE novels.id = codex_entries.novel_id AND (novels.status = 'Published' OR novels.user_id = auth.uid())
    )
  );

