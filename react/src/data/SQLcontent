-- 1. Create the functional database listener engine
CREATE OR REPLACE FUNCTION public.handle_new_user_signup()
RETURNS TRIGGER AS $$
BEGIN
  INSERT INTO public.profiles (id, username, display_name, avatar_url, bio)
  VALUES (
    NEW.id,
    -- Generates a temporary unique username using their email prefix + random numbers
    LOWER(SPLIT_PART(NEW.email, '@', 1)) || '_' || FLOOR(RANDOM() * 1000)::TEXT,
    -- Sets default display name to email prefix
    SPLIT_PART(NEW.email, '@', 1),
    -- Clean default placeholder robot avatar using their unique ID as a variant seed
    'https://api.dicebear.com/7.x/bottts/svg?seed=' || NEW.id::TEXT,
    'A new dynamic storyteller on the platform.'
  );
  RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- 2. Attach the trigger mechanism to execution lifecycle of auth.users
CREATE OR REPLACE TRIGGER on_auth_user_created_profile
  AFTER INSERT ON auth.users
  FOR EACH ROW EXECUTE PROCEDURE public.handle_new_user_signup();

